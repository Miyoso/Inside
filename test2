  {
    id: 1,
    question: "Un deal tourne mal. Ton associé est neutralisé. Tu fais quoi ?",
    options: [
      "Tu récupères la marchandise et tu disparais",
      "Tu attends les secours sur place",
      "Tu appelles les flics toi-même",
      "Tu abandonnes tout et tu cours",
    ],
    correct: 0,
  },
  {
    id: 2,
    question: "Quelle est la règle d'or dans le milieu ?",
    options: [
      "Toujours faire confiance à ton équipe",
      "Ne jamais parler aux inconnus",
      "On ne laisse aucune trace, aucun témoin",
      "L'argent avant tout",
    ],
    correct: 2,
  },
  {
    id: 3,
    question: "Une livraison est interceptée par une unité rivale. Tu as 3 hommes. Quelle stratégie ?",
    options: [
      "Négocier un partage",
      "Contournement par le nord, récupération discrète",
      "Attaque frontale immédiate",
      "Appeler des renforts et attendre",
    ],
